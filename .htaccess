RewriteEngine On

# Bloquea acceso web a rutas/archivos sensibles del proyecto.
RewriteRule ^(?:app|storage|\.git|\.vscode)(?:/|$) - [F,L,NC]
RewriteRule ^(?:streaming_renovaciones.*\.sql)$ - [F,L,NC]
RewriteRule ^(?:README\.md|AGENTS\.md)$ - [F,L,NC]
RewriteRule ^\.(?!well-known/) - [F,L,NC]

# Sirve archivos estaticos reales desde /public. Funciona tanto si el proyecto
# esta en la raiz del dominio como en una subcarpeta (p. ej. /streaming-renovaciones/).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+\.(?:png|jpe?g|gif|svg|ico|webp|avif|css|js|mjs|map|woff2?|ttf|eot|otf|txt|pdf|mp4|webm))$ public/$1 [L,NC]

# Front controller en raiz (carga public/index.php).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
